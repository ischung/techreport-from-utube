# ────────────────────────────────────────────────────────────────
# TechReport from YouTube — environment configuration template
# Copy to .env and fill in the values. Never commit the real .env.
# ────────────────────────────────────────────────────────────────

# LLM provider selection — switch between adapters at runtime
# Valid values: claude | openai | ollama
LLM_PROVIDER=claude

# Required when LLM_PROVIDER=claude
ANTHROPIC_API_KEY=

# Optional — needed only if you swap to LLM_PROVIDER=openai
OPENAI_API_KEY=

# Optional — needed only if you swap to LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434

# YouTube Data API v3 key (search.list)
YOUTUBE_API_KEY=

# Where generated technical reports are saved (git-ignored directory)
REPORTS_DIR=./reports
